{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "munimarcala",
  "main": "worker/index.js",
  "compatibility_date": "2026-05-23",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public_build",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
